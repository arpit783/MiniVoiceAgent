# MiniVoiceAgent Environment Configuration
# Copy this file to .env and fill in your API keys
# cp .env.example .env

# =============================================================================
# LLM Configuration (choose one)
# =============================================================================

# Google Gemini (FREE tier available!)
# Get your key at: https://aistudio.google.com/
GEMINI_API_KEY=

# OpenAI (alternative to Gemini)
# Get your key at: https://platform.openai.com/
OPENAI_API_KEY=

# LLM model to use (default: gpt-4o for OpenAI, gemini-pro for Gemini)
LLM_MODEL=gpt-4o

# =============================================================================
# Speech-to-Text (STT) - Deepgram
# =============================================================================

# Get your key at: https://deepgram.com/
DEEPGRAM_API_KEY=

# Deepgram model (default: nova-2)
STT_MODEL=nova-2

# =============================================================================
# Text-to-Speech (TTS) - ElevenLabs
# =============================================================================

# Get your key at: https://elevenlabs.io/
ELEVENLABS_API_KEY=

# ElevenLabs voice ID (default: Rachel - 21m00Tcm4TlvDq8ikWAM)
# Find more voices at: https://elevenlabs.io/voice-library
TTS_VOICE_ID=21m00Tcm4TlvDq8ikWAM

# =============================================================================
# LiveKit Configuration (Optional - for WebRTC mode)
# =============================================================================

# LiveKit server URL
LIVEKIT_URL=wss://localhost:7880

# LiveKit API credentials
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# Default room name
DEFAULT_ROOM=voice-agent-room

# =============================================================================
# Agent Configuration
# =============================================================================

# Agent name/identifier
AGENT_NAME=VoiceAgent

# Enable barge-in detection (user interruption handling)
ENABLE_BARGE_IN=true
